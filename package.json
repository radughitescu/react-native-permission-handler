{
  "name": "react-native-permission-handler",
  "version": "0.0.0",
  "description": "Smart permission UX flows for React Native — pre-prompts, blocked handling, settings redirect & foreground re-check. Built on react-native-permissions.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "permissions",
    "permission",
    "permission-flow",
    "soft-prompt",
    "pre-prompt",
    "permission-ux",
    "ios",
    "android",
    "settings",
    "runtime-permissions",
    "permission-handler"
  ],
  "author": "Radu Ghitescu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radughitescu/react-native-permission-handler.git"
  },
  "bugs": {
    "url": "https://github.com/radughitescu/react-native-permission-handler/issues"
  },
  "homepage": "https://github.com/radughitescu/react-native-permission-handler#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-permissions": ">=4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.76.0",
    "react-native-permissions": "^4.0.0",
    "react-test-renderer": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
