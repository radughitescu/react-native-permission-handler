{
  "name": "react-native-permission-handler",
  "version": "0.8.1",
  "description": "Smart permission UX flows for React Native — pre-prompts, blocked handling, settings redirect & foreground re-check. Pluggable engine: works with react-native-permissions, Expo, or your own.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./rnp": {
      "import": {
        "types": "./dist/engines/rnp.d.mts",
        "default": "./dist/engines/rnp.mjs"
      },
      "require": {
        "types": "./dist/engines/rnp.d.ts",
        "default": "./dist/engines/rnp.js"
      }
    },
    "./expo": {
      "import": {
        "types": "./dist/engines/expo.d.mts",
        "default": "./dist/engines/expo.mjs"
      },
      "require": {
        "types": "./dist/engines/expo.d.ts",
        "default": "./dist/engines/expo.js"
      }
    },
    "./noop": {
      "import": {
        "types": "./dist/engines/noop.d.mts",
        "default": "./dist/engines/noop.mjs"
      },
      "require": {
        "types": "./dist/engines/noop.d.ts",
        "default": "./dist/engines/noop.js"
      }
    },
    "./testing": {
      "import": {
        "types": "./dist/engines/testing.d.mts",
        "default": "./dist/engines/testing.mjs"
      },
      "require": {
        "types": "./dist/engines/testing.d.ts",
        "default": "./dist/engines/testing.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react-native",
    "permissions",
    "permission",
    "permission-flow",
    "soft-prompt",
    "pre-prompt",
    "permission-ux",
    "ios",
    "android",
    "settings",
    "runtime-permissions",
    "permission-handler"
  ],
  "author": "Radu Ghitescu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radughitescu/react-native-permission-handler.git"
  },
  "bugs": {
    "url": "https://github.com/radughitescu/react-native-permission-handler/issues"
  },
  "homepage": "https://github.com/radughitescu/react-native-permission-handler#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-permissions": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "react-native-permissions": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.76.0",
    "react-native-permissions": "^5.5.1",
    "react-test-renderer": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.6.0",
    "vitest": "^3.0.0"
  }
}
